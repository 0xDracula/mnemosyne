<div class="mn-section-label">[ SIGN IN ]</div>

<div class="mn-panel">
  <p class="mb-6">authenticate with hack club auth to continue. access beyond this point is restricted to allowlisted staff and logged accordingly.</p>

  <%= form_tag "/auth/hackclub", method: :post, authenticity_token: false, data: { turbo: false } do %>
    <%= hidden_field_tag :authenticity_token, Rack::Protection::AuthenticityToken.token(session) %>
    <%= submit_tag "log in with hack club auth", class: "mn-btn-accent" %>
  <% end %>
</div>

<p class="mn-stamp mt-6">mnemosyne &middot; community manager + fire engine portal</p>
